# Copy to .env in the repo root before running: docker compose up -d --build
#
# Azure AD redirect URI must include http://localhost:8080 (or your WEB_PORT)
# as a Single-page application redirect in the Entra ID app registration.

POSTGRES_USER=spcs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=spcs_transcripts

AZURE_TENANT_ID=ef6ae8ee-9884-4ff6-9ebc-86f882c072c7
AZURE_CLIENT_ID=081ab41b-8188-4deb-b5b5-6ac4089f8997
BOOTSTRAP_ADMIN_EMAIL=spcscky@spcs.edu.hk

# Host port mapped to the Nginx container (8080 avoids requiring admin on Windows)
WEB_PORT=8000
