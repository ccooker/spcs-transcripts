datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  ADMIN
  STAFF
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum FormLevel {
  FORM_1
  FORM_2
  FORM_3
  FORM_4
  FORM_5
  FORM_6
}

enum TranscriptStatus {
  DRAFT
  FINALISED
  NONE
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  displayName String
  role        Role       @default(STAFF)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  auditLogs   AuditLog[] @relation("ActingUser")
}

model AuditLog {
  id           String      @id @default(uuid())
  actingUserId String
  actingUser   User        @relation("ActingUser", fields: [actingUserId], references: [id])
  action       AuditAction
  model        String
  recordId     String
  details      String?
  timestamp    DateTime    @default(now())

  @@index([actingUserId])
  @@index([model, recordId])
  @@index([timestamp])
}

model Student {
  id              String           @id @default(uuid())
  fullName        String
  formLevel       FormLevel
  graduationYear  Int
  schoolStudentId String           @unique
  studentEmail    String?
  studentPhone    String?
  parentEmail     String?
  parentPhone     String?
  transcriptStatus TranscriptStatus @default(NONE)
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([fullName])
  @@index([formLevel, archivedAt])
  @@index([transcriptStatus])
  @@index([archivedAt])
}
